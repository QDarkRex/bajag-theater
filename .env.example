# Environment Configuration
NODE_ENV="development" # Options: 'development', 'production'
PORT="6969"            # The port your server will listen on
HOST="localhost"       # Hostname for the server

# CORS Settings
CORS_ORIGIN="http://localhost:6969" # Allowed CORS origin, adjust as necessary

# Rate Limiting
COMMON_RATE_LIMIT_WINDOW_MS="1000" # Window size for rate limiting (ms)
COMMON_RATE_LIMIT_MAX_REQUESTS="20" # Max number of requests per window per IP
COOKIES=cookies/cookies # Netscape or Cookie-header file exported from your paid IDN account session
REPLAY_DIR=${PWD}/replay
HW_ACCEL=VAAPI
FFMPEG_PATH=/usr/bin/ffmpeg
DOWNLOAD_DIR=${PWD}/download
PROXY_URL=http://localhost:6969/livestream/proxy
IDN_USERNAME=jkt48-official
IDN_LIVE_URL=

# Optional web/VLC authentication. Leave all three empty to disable authentication.
# Never commit real credentials. Generate the secret with: openssl rand -hex 32
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=43200
