# Environment Configuration
# Options: development, production
NODE_ENV=development
# The port your server will listen on
PORT=6969
# Hostname for the server
HOST=localhost

# CORS Settings
# Allowed CORS origin; adjust as necessary.
CORS_ORIGIN=http://localhost:6969

# Rate Limiting
# Docker --env-file treats inline comments as part of the value, so keep values plain.
COMMON_RATE_LIMIT_WINDOW_MS=1000
COMMON_RATE_LIMIT_MAX_REQUESTS=20
# Netscape or Cookie-header file exported from your paid IDN account session.
COOKIES=cookies/cookies
REPLAY_DIR=${PWD}/replay
HW_ACCEL=VAAPI
FFMPEG_PATH=/usr/bin/ffmpeg
DOWNLOAD_DIR=${PWD}/download
PROXY_URL=http://localhost:6969/livestream/proxy
IDN_USERNAME=jkt48-official
IDN_LIVE_URL=

# Optional web/VLC authentication. Leave all three empty to disable authentication.
# Never commit real credentials. Generate the secret with: openssl rand -hex 32
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=43200
