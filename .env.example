# Environment Configuration
NODE_ENV="development" # Options: 'development', 'production'
PORT="3000"            # The port your server will listen on
HOST="localhost"       # Hostname for the server

# CORS Settings
CORS_ORIGIN="http://localhost:*" # Allowed CORS origin, adjust as necessary

# Rate Limiting
COMMON_RATE_LIMIT_WINDOW_MS="1000" # Window size for rate limiting (ms)
COMMON_RATE_LIMIT_MAX_REQUESTS="20" # Max number of requests per window per IP
COOKIES=cookies # the path for cookies file
REPLAY_DIR=${PWD}/replay
HW_ACCEL=VAAPI
FFMPEG_PATH=/usr/bin/ffmpeg
DOWNLOAD_DIR=${PWD}/download
PROXY_URL=http://localhost:3000/livestream/proxy
IDN_USERNAME=jkt48-official
